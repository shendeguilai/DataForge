[Unit]
Description=DataForge daily PostgreSQL and artifact backup
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
User=dataforge
Group=dataforge
SupplementaryGroups=docker
Environment=DATAFORGE_ENV_FILE=/etc/dataforge/dataforge.env
WorkingDirectory=/opt/dataforge/app
ExecStart=/opt/dataforge/app/scripts/prod.sh backup
