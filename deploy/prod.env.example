# 复制到 /etc/dataforge/dataforge.env，替换所有 CHANGE_ME，并执行 chmod 600。
COMPOSE_PROJECT_NAME=dataforge
DATAFORGE_IMAGE_TAG=local
PUBLIC_PORT=8080

POSTGRES_DB=dataforge
POSTGRES_USER=dataforge
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DATABASE_POOL_SIZE=10

DATAFORGE_POSTGRES_DIR=/srv/dataforge/postgres
DATAFORGE_RUNTIME_DIR_HOST=/srv/dataforge/runtime
DATAFORGE_BACKUP_DIR=/srv/dataforge/backups
DATAFORGE_MIGRATION_DIR=/srv/dataforge/migration

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
INVITE_CODE=CHANGE_ME_INVITE_CODE
DATAFORGE_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS

DAILY_GENERATION_LIMIT=30
DATAFORGE_PROCESS_STACK_MB=256

AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-v4-pro
ATCODER_COOKIE=

# 仅首次 H2 迁移使用。若旧环境从未设置过该变量，旧默认值是：
# change-this-secret-before-production
LEGACY_DATAFORGE_SECRET=
LEGACY_ALLOW_MISSING_ARTIFACTS=false
